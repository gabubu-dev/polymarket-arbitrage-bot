{
  "api": {
    "base_url": "https://clob.polymarket.com",
    "gamma_api_url": "https://gamma-api.polymarket.com",
    "rate_limit": 10,
    "timeout": 30,
    "retry_attempts": 3
  },
  "arbitrage": {
    "divergence_threshold": 0.05,
    "min_profit_threshold": 0.02,
    "max_position_size": 1000,
    "excluded_markets": []
  },
  "trading": {
    "max_positions": 5,
    "position_size_usd": 100,
    "enabled": false
  },
  "risk": {
    "stop_loss_percentage": 0.15,
    "take_profit_percentage": 0.90,
    "max_daily_loss_usd": 1000.0,
    "emergency_shutdown_loss_usd": 5000.0
  },
  "polling": {
    "max_requests_per_second": 10.0,
    "strategy": "adaptive",
    "enable_caching": true
  },
  "whale_tracking": {
    "min_order_size_usd": 5000,
    "tracking_window_seconds": 300,
    "whale_address_threshold": 0.6,
    "follow_threshold": 0.6
  },
  "sentiment": {
    "volume_change_threshold": 0.5,
    "momentum_threshold": 0.1,
    "lookback_hours": 24
  },
  "data": {
    "cache_enabled": true,
    "cache_ttl": 300,
    "database_path": "data/markets.db"
  },
  "dashboard": {
    "host": "127.0.0.1",
    "port": 8080,
    "refresh_interval": 30,
    "theme": "plotly_dark"
  },
  "visualization": {
    "default_theme": "plotly_dark",
    "chart_height": 500,
    "chart_width": 1000
  },
  "wallets": {
    "tracked_addresses": []
  },
  "logging": {
    "level": "INFO",
    "log_file": "logs/bot.log",
    "trade_log": "logs/trades.log",
    "error_log": "logs/errors.log"
  },
  "production": {
    "max_restart_attempts": 5,
    "health_check_interval": 60
  }
}
